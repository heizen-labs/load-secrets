{
  "name": "load-secrets",
  "version": "1.0.0",
  "description": "GitHub Action to load environment secrets from Heizen Project Studio.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "bun run clean && tsc && ncc build dist/main.js -o dist",
    "build:dev": "tsc",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "prepare": "bun run build"
  },
  "keywords": [
    "github-action",
    "secrets",
    "heizen"
  ],
  "author": "Heizen Labs",
  "license": "ISC",
  "packageManager": "bun@1.2.15",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^2.0.1",
    "axios": "^1.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}
